<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sky.mapper.SetmealDishMapper">
    <select id="getSetmealDishByDishId" resultType="Long">
         select setmeal_id from setmeal_dish where dish_id in
        <foreach collection="list" item="item" separator="," open="(" close=")">
            #{item}
        </foreach>
    </select>
    <select id="getSetmealDishBySetmealId" resultType="com.sky.vo.DishItemVO">
        select dish.name,copies,image,description from setmeal_dish
        left join  dish on setmeal_dish.dish_id=dish.id
        where setmeal_id=#{SetmealId}
    </select>
    <insert id="insertBatch" >
        insert into setmeal_dish (setmeal_id,dish_id,copies,name,price) values
        <foreach collection="list" item="item" separator=",">
            (#{item.setmealId},#{item.dishId},#{item.copies},#{item.name},#{item.price})
        </foreach>
    </insert>
</mapper>