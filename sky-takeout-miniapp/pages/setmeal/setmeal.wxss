/* pages/setmeal/setmeal.wxss */
.setmeal-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 80px;
}

.setmeal-hero {
  width: 100%;
  height: 480rpx;
  background: #f0f0f0;
}

/* 卡片 */
.card {
  background: #fff;
  margin: 12px;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.setmeal-info {
  margin-top: -20px;
  position: relative;
  z-index: 1;
}

.setmeal-name {
  display: block;
  font-size: 22px;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 6px;
}

.setmeal-desc {
  display: block;
  font-size: 13px;
  color: #999;
  margin-bottom: 14px;
  line-height: 1.5;
}

.setmeal-price-row {
  display: flex;
  align-items: baseline;
  gap: 10px;
}

.price-box {
  display: flex;
  align-items: baseline;
}

.price-unit {
  font-size: 14px;
  font-weight: 700;
  color: #ff4d4f;
}

.price-value {
  font-size: 28px;
  font-weight: 700;
  color: #ff4d4f;
}

.origin-price {
  font-size: 14px;
  color: #bbb;
  text-decoration: line-through;
}

/* 套餐包含 */
.section-title {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12px;
}

.include-dish {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 0.5px solid #f5f5f5;
}

.include-dish:last-child {
  border-bottom: none;
}

.include-img {
  width: 56px;
  height: 56px;
  border-radius: 8px;
  margin-right: 12px;
  background: #f5f5f5;
}

.include-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.include-name {
  font-size: 14px;
  color: #333;
}

.include-copies {
  font-size: 13px;
  color: #ff6b35;
  font-weight: 600;
}

/* 底部栏 */
.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px;
  box-shadow: 0 -2px 12px rgba(0,0,0,0.06);
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.bottom-left {
  display: flex;
  align-items: baseline;
}

.bottom-price-unit {
  font-size: 14px;
  font-weight: 700;
  color: #ff4d4f;
}

.bottom-price {
  font-size: 24px;
  font-weight: 700;
  color: #ff4d4f;
}

.add-cart-btn {
  padding: 10px 36px;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  color: #fff;
  border-radius: 24px;
  font-size: 15px;
  font-weight: 600;
  border: none;
  box-shadow: 0 4px 12px rgba(255, 107, 53, 0.35);
}
