/* pages/index/index.wxss */
.home-page {
  background: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* === 顶栏 === */
.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 44px 16px 12px;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  color: #fff;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.header-logo {
  width: 28px;
  height: 28px;
  border-radius: 6px;
  background: rgba(255,255,255,0.3);
}

.header-title {
  font-size: 18px;
  font-weight: 700;
  letter-spacing: 2px;
}

.shop-badge {
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 500;
}
.shop-badge.open {
  background: rgba(255,255,255,0.25);
  color: #fff;
}
.shop-badge.closed {
  background: rgba(0,0,0,0.15);
  color: rgba(255,255,255,0.7);
}

/* === 分类栏 === */
.category-bar {
  background: #fff;
  border-bottom: 0.5px solid #f0f0f0;
  white-space: nowrap;
}
.category-scroll {
  display: inline-flex;
  padding: 10px 8px;
  gap: 2px;
}
.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 62px;
  padding: 6px 4px;
  border-radius: 8px;
  transition: all 0.15s;
}
.category-item.active {
  background: #fff5f0;
}
.cate-icon-wrap {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4px;
}
.category-item.active .cate-icon-wrap {
  background: #ff6b35;
}
.cate-icon {
  font-size: 16px;
}
.cate-name {
  font-size: 11px;
  color: #666;
}
.category-item.active .cate-name {
  color: #ff6b35;
  font-weight: 600;
}

/* === 商品滚动区 === */
.goods-scroll {
  flex: 1;
  height: 0;
}

.section-header {
  display: flex;
  align-items: baseline;
  padding: 16px 16px 8px;
  gap: 8px;
}
.section-title {
  font-size: 16px;
  font-weight: 700;
  color: #1a1a1a;
}
.section-sub {
  font-size: 11px;
  color: #999;
}

/* === 商品卡片 === */
.goods-list {
  padding: 0 12px;
}
.goods-card {
  display: flex;
  background: #fff;
  border-radius: 12px;
  margin-bottom: 10px;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}
.goods-img {
  width: 110px;
  height: 110px;
  flex-shrink: 0;
  background: #f5f5f5;
}
.goods-body {
  flex: 1;
  padding: 12px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}
.goods-name {
  font-size: 15px;
  font-weight: 600;
  color: #1a1a1a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.goods-desc {
  font-size: 11px;
  color: #999;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-top: 2px;
}
.goods-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 6px;
}
.goods-price {
  display: flex;
  align-items: baseline;
}
.price-unit {
  font-size: 12px;
  font-weight: 700;
  color: #ff4d4f;
}
.price-num {
  font-size: 20px;
  font-weight: 700;
  color: #ff4d4f;
  line-height: 1;
}

/* === 加购按钮 === */
.add-cart-btn {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 6px rgba(255,107,53,0.4);
}
.add-icon {
  font-size: 18px;
  color: #fff;
  font-weight: 400;
  line-height: 1;
}

/* === 空状态 === */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 0;
}
.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}
.empty-text {
  font-size: 14px;
  color: #999;
}

/* === 底部安全区 === */
.bottom-safe {
  height: 80px;
}
