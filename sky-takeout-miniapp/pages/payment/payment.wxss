/* pages/payment/payment.wxss */
.payment-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 头部 */
.pay-header {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  padding: 44px 16px 16px;
  color: #fff;
}
.pay-header-title {
  font-size: 20px;
  font-weight: 700;
}

/* 金额卡片 */
.amount-card {
  background: #fff;
  margin: 16px 12px;
  border-radius: 12px;
  padding: 28px 20px;
  text-align: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.amount-label {
  display: block;
  font-size: 14px;
  color: #999;
  margin-bottom: 8px;
}
.amount-row {
  display: flex;
  justify-content: center;
  align-items: baseline;
  margin-bottom: 12px;
}
.amount-unit {
  font-size: 22px;
  font-weight: 700;
  color: #1a1a1a;
}
.amount-value {
  font-size: 48px;
  font-weight: 700;
  color: #1a1a1a;
}
.amount-order-no {
  display: block;
  font-size: 12px;
  color: #bbb;
}

/* 支付方式 */
.card {
  background: #fff;
  margin: 0 12px 12px;
  border-radius: 12px;
  padding: 16px;
}
.section-title {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

.pay-method-item {
  display: flex;
  align-items: center;
  padding: 14px 0;
  border-bottom: 0.5px solid #f5f5f5;
}
.pay-method-item:last-child {
  border-bottom: none;
}
.method-icon {
  font-size: 24px;
  margin-right: 12px;
}
.method-name {
  flex: 1;
  font-size: 15px;
  color: #333;
}
.method-check {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 2px solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: #fff;
}
.method-check.checked {
  background: #ff6b35;
  border-color: #ff6b35;
}

/* 倒计时 */
.timeout-tip {
  text-align: center;
  padding: 16px;
  font-size: 12px;
  color: #999;
}

/* 支付按钮 */
.pay-btn-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  box-shadow: 0 -2px 8px rgba(0,0,0,0.06);
}
.pay-btn {
  width: 100%;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  color: #fff;
  border-radius: 24px;
  font-size: 17px;
  font-weight: 700;
  border: none;
  height: 50px;
  line-height: 50px;
  box-shadow: 0 4px 16px rgba(255,107,53,0.35);
}
