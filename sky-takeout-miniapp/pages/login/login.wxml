<!--pages/login/login.wxml-->
<view class="login-page">
  <view class="login-brand">
    <view class="brand-circle">
      <text class="brand-emoji">🛵</text>
    </view>
    <text class="brand-name">准时达生活平台</text>
    <text class="brand-desc">新鲜食材 · 准时送达 · 品质生活</text>
  </view>

  <view class="login-bottom">
    <view class="login-card">
      <text class="login-title">欢迎光临</text>
      <text class="login-subtitle">授权登录开启便捷生活</text>

      <button class="wx-login-btn" loading="{{loading}}" bindtap="handleLogin">
        <text wx:if="{{!loading}}">微信一键登录</text>
        <text wx:else>登录中...</text>
      </button>

      <view class="login-error" wx:if="{{loginFailed}}">
        <text>{{errorMsg || '登录失败，请重试'}}</text>
      </view>

      <view class="login-agreement">
        <text>登录即表示同意《用户协议》和《隐私政策》</text>
      </view>
    </view>
  </view>
</view>
