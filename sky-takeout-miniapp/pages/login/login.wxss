/* pages/login/login.wxss */
.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #fff;
}

.login-brand {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #ff6b35 0%, #ff8c42 40%, #ffab76 100%);
  padding: 80px 40px 50px;
}

.brand-circle {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
}

.brand-emoji {
  font-size: 44px;
}

.brand-name {
  font-size: 28px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4px;
}

.brand-desc {
  font-size: 13px;
  color: rgba(255,255,255,0.8);
  margin-top: 12px;
  letter-spacing: 4px;
}

.login-bottom {
  flex: 1;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 50px 32px;
}

.login-card {
  width: 100%;
  text-align: center;
}

.login-title {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8px;
}

.login-subtitle {
  display: block;
  font-size: 14px;
  color: #999;
  margin-bottom: 40px;
}

.wx-login-btn {
  width: 100%;
  height: 50px;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  color: #fff;
  border-radius: 25px;
  font-size: 16px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.wx-login-btn::after {
  border: none;
}

.login-error {
  margin-top: 20px;
  padding: 12px;
  background: #fff2f0;
  border-radius: 8px;
  color: #ff4d4f;
  font-size: 13px;
}

.login-agreement {
  margin-top: 32px;
  font-size: 11px;
  color: #bbb;
}
