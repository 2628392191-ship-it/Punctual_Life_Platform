/* pages/mine/mine.wxss */
.mine-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.mine-header {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  padding: 60px 20px 30px;
  display: flex;
  align-items: center;
}
.avatar-wrap {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  border: 3px solid rgba(255,255,255,0.5);
  overflow: hidden;
  margin-right: 16px;
  flex-shrink: 0;
}
.avatar {
  width: 100%;
  height: 100%;
  background: #e0e0e0;
}
.user-info {
  flex: 1;
  color: #fff;
}
.user-name {
  display: block;
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 4px;
}
.user-id {
  display: block;
  font-size: 13px;
  opacity: 0.8;
}
.edit-icon {
  font-size: 22px;
  color: rgba(255,255,255,0.7);
}

/* 数据概览 */
.stats-row {
  display: flex;
  background: #fff;
  margin: -16px 12px 12px;
  border-radius: 12px;
  padding: 16px 0;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  position: relative;
  z-index: 1;
}
.stat-item {
  flex: 1;
  text-align: center;
}
.stat-num {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 4px;
}
.stat-label {
  font-size: 12px;
  color: #999;
}

/* 菜单区域 */
.menu-section {
  background: #fff;
  margin: 8px 12px;
  border-radius: 12px;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 16px;
  border-bottom: 0.5px solid #f5f5f5;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-icon {
  font-size: 18px;
  margin-right: 12px;
}
.menu-text {
  flex: 1;
  font-size: 15px;
  color: #333;
}
.arrow {
  font-size: 20px;
  color: #ccc;
}
.shop-status-right {
  display: flex;
  align-items: center;
  gap: 8px;
}
.status-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
}
.status-dot.open { background: #52c41a; }
.status-dot.close { background: #ff4d4f; }
.status-text {
  font-size: 13px;
  color: #999;
}

/* 退出 */
.logout-section {
  margin-top: 32px;
  padding: 0 12px 40px;
}
.logout-btn {
  width: 100%;
  background: #fff;
  color: #ff4d4f;
  border-radius: 12px;
  font-size: 15px;
  border: none;
  height: 48px;
  line-height: 48px;
}
