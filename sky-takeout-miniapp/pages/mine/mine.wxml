<!--pages/mine/mine.wxml-->
<view class="mine-page">
  <!-- 用户信息卡片 -->
  <view class="mine-header">
    <view class="avatar-wrap">
      <image class="avatar" src="{{userInfo.avatar || '/images/avatar-default.png'}}" mode="aspectFill" />
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.name || '微信用户'}}</text>
      <text class="user-id">ID: {{userInfo.id || '--'}}</text>
    </view>
    <text class="edit-icon">⚙</text>
  </view>

  <!-- 数据概览 -->
  <view class="stats-row">
    <view class="stat-item" bindtap="goToOrders">
      <text class="stat-num">{{orderCount || 0}}</text>
      <text class="stat-label">全部订单</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{addressCount || 0}}</text>
      <text class="stat-label">收货地址</text>
    </view>
  </view>

  <!-- 常用功能 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goAddress">
      <text class="menu-icon">📍</text>
      <text class="menu-text">收货地址</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goShopStatus">
      <text class="menu-icon">🏪</text>
      <text class="menu-text">店铺状态</text>
      <view class="shop-status-right">
        <view class="status-dot {{shopOpen ? 'open' : 'close'}}"></view>
        <text class="status-text">{{shopOpen ? '营业中' : '休息中'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToOrders">
      <text class="menu-icon">📋</text>
      <text class="menu-text">全部订单</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
</view>
