<!--pages/cart/cart.wxml-->
<view class="cart-page">
  <!-- 头部 -->
  <view class="cart-header">
    <text class="cart-header-title">购物车</text>
    <view class="cart-header-right" wx:if="{{cartItems.length > 0}}">
      <text class="cart-header-count">{{cartItems.length}}件</text>
      <text class="cart-clear" bindtap="clearCart">清空</text>
    </view>
  </view>

  <view class="cart-list" wx:if="{{cartItems.length > 0}}">
    <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
      <image class="cart-item-img" src="{{item.image || '/images/placeholder.png'}}" mode="aspectFill" />
      <view class="cart-item-info">
        <text class="cart-item-name">{{item.name}}</text>
        <text class="cart-item-flavor" wx:if="{{item.dishFlavor}}">{{item.dishFlavor}}</text>
        <view class="cart-item-bottom">
          <view class="cart-price">
            <text class="price-unit">¥</text>
            <text class="price-num">{{item.lineTotal}}</text>
          </view>
          <view class="qty-ctrl">
            <view class="qty-btn" data-item="{{item}}" catchtap="subItem">-</view>
            <text class="qty-num">{{item.number}}</text>
            <view class="qty-btn qty-plus" data-item="{{item}}" catchtap="addItem">+</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车是空的</text>
    <text class="empty-tip">快去首页逛逛吧</text>
  </view>

  <view class="cart-bottom safe-bottom" wx:if="{{cartItems.length > 0}}">
    <view class="total-area">
      <text class="total-label">合计 </text>
      <view class="cart-price">
        <text class="price-unit">¥</text>
        <text class="price-total">{{totalPrice}}</text>
      </view>
    </view>
    <button class="checkout-btn" bindtap="goCheckout">去结算</button>
  </view>
</view>
