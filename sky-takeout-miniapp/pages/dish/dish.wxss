/* pages/dish/dish.wxss */
.dish-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 80px;
}

.dish-hero {
  width: 100%;
  height: 480rpx;
  background: #f0f0f0;
}

/* 菜品信息卡片 */
.card {
  background: #fff;
  margin: 12px;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.dish-info {
  margin-top: -20px;
  position: relative;
  z-index: 1;
}

.dish-name {
  display: block;
  font-size: 22px;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 6px;
}

.dish-desc {
  display: block;
  font-size: 13px;
  color: #999;
  margin-bottom: 14px;
  line-height: 1.5;
}

.dish-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-box {
  display: flex;
  align-items: baseline;
}

.price-unit {
  font-size: 14px;
  font-weight: 700;
  color: #ff4d4f;
}

.price-big {
  font-size: 28px;
  font-weight: 700;
  color: #ff4d4f;
}

.sales-info {
  font-size: 12px;
  color: #bbb;
  background: #fafafa;
  padding: 4px 10px;
  border-radius: 10px;
}

/* 口味选择 */
.dish-flavor {
  margin-top: 0;
}

.section-title {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12px;
}

.flavor-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.flavor-item {
  padding: 8px 18px;
  background: #f5f5f5;
  border-radius: 20px;
  font-size: 13px;
  color: #666;
  border: 1.5px solid transparent;
  transition: all 0.2s;
}

.flavor-item.active {
  background: #fff5f0;
  color: #ff6b35;
  border-color: #ff6b35;
  font-weight: 600;
}

/* 底部栏 */
.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px;
  box-shadow: 0 -2px 12px rgba(0,0,0,0.06);
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.bottom-left {
  display: flex;
  align-items: baseline;
}

.bottom-price-unit {
  font-size: 14px;
  font-weight: 700;
  color: #ff4d4f;
}

.bottom-price {
  font-size: 24px;
  font-weight: 700;
  color: #ff4d4f;
}

.add-cart-btn {
  padding: 10px 36px;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  color: #fff;
  border-radius: 24px;
  font-size: 15px;
  font-weight: 600;
  border: none;
  box-shadow: 0 4px 12px rgba(255, 107, 53, 0.35);
}
