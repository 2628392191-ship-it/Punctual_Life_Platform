<!--pages/dish/dish.wxml-->
<view class="dish-page">
  <image class="dish-hero" src="{{dish.image || '/images/placeholder.png'}}" mode="aspectFill" />

  <view class="dish-info card">
    <text class="dish-name">{{dish.name}}</text>
    <text class="dish-desc" wx:if="{{dish.description}}">{{dish.description}}</text>
    <view class="dish-price-row">
      <view class="price-box">
        <text class="price-unit">¥</text>
        <text class="price-big">{{dish.price}}</text>
      </view>
      <text class="sales-info">月售 {{dish.sales || 0}} 份</text>
    </view>
  </view>

  <view class="dish-flavor card" wx:if="{{dish.flavors && dish.flavors.length > 0}}">
    <text class="section-title">口味选择</text>
    <view class="flavor-list">
      <view
        class="flavor-item {{selectedFlavor === item.name ? 'active' : ''}}"
        wx:for="{{dish.flavors}}"
        wx:key="name"
        bindtap="selectFlavor"
        data-name="{{item.name}}">
        {{item.name}}
      </view>
    </view>
  </view>

  <view class="fixed-bottom safe-bottom">
    <view class="bottom-left">
      <text class="bottom-price-unit">¥</text>
      <text class="bottom-price">{{dish.price}}</text>
    </view>
    <button class="add-cart-btn" bindtap="addToCart">加入购物车</button>
  </view>
</view>
