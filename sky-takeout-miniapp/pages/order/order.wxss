/* pages/order/order.wxss */
.order-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 80px;
}

.order-header-bar {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  padding: 44px 16px 16px;
  color: #fff;
}
.order-header-title {
  font-size: 20px;
  font-weight: 700;
}

/* 标签栏 */
.order-tabs {
  display: flex;
  background: #fff;
  padding: 4px 8px;
  border-bottom: 0.5px solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 12px 0;
  font-size: 13px;
  color: #666;
  position: relative;
}
.tab-item.active {
  color: #ff6b35;
  font-weight: 700;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  width: 40%;
  height: 2.5px;
  background: #ff6b35;
  border-radius: 2px;
}

/* 订单卡片 */
.order-list {
  padding: 8px 12px;
}
.order-card {
  background: #fff;
  margin-bottom: 10px;
  border-radius: 12px;
  padding: 14px 16px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}
.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.order-shop {
  font-size: 14px;
  font-weight: 600;
  color: #1a1a1a;
}
.order-status {
  font-size: 13px;
  font-weight: 600;
}
.order-items {
  padding: 10px 0;
  border-top: 0.5px solid #f5f5f5;
  border-bottom: 0.5px solid #f5f5f5;
}
.order-item-name {
  display: block;
  font-size: 13px;
  color: #666;
  margin: 3px 0;
  line-height: 1.5;
}
.order-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10px;
}
.order-time {
  font-size: 12px;
  color: #999;
}
.order-total {
  display: flex;
  align-items: baseline;
}
.total-label {
  font-size: 12px;
  color: #999;
}
.order-price {
  display: flex;
  align-items: baseline;
}
.order-price .price-unit {
  font-size: 12px;
  font-weight: 700;
  color: #ff4d4f;
}
.order-price .price-num {
  font-size: 18px;
  font-weight: 700;
  color: #ff4d4f;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 0.5px solid #f5f5f5;
}
.action-btn {
  padding: 8px 18px;
  border-radius: 18px;
  font-size: 12px;
  border: none;
  font-weight: 500;
}
.pay-btn {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  color: #fff;
}
.cancel-btn {
  background: #f5f5f5;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100px 0;
}
.empty-icon {
  font-size: 56px;
  margin-bottom: 16px;
}
.empty-text {
  font-size: 16px;
  color: #666;
  margin-bottom: 4px;
}
.empty-tip {
  font-size: 13px;
  color: #999;
}

/* 订单详情弹窗 */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.detail-popup {
  background: #fff;
  border-radius: 16px 16px 0 0;
  width: 100%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}
.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 0.5px solid #f0f0f0;
}
.detail-title {
  font-size: 17px;
  font-weight: 700;
}
.detail-close {
  font-size: 20px;
  color: #999;
  padding: 4px 8px;
}
.detail-body {
  padding: 16px;
  overflow-y: auto;
}
.detail-status {
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 6px;
}
.detail-order-no {
  font-size: 12px;
  color: #999;
  display: block;
  margin-bottom: 16px;
}
.detail-section {
  margin-bottom: 16px;
}
.detail-section-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}
.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
}
.detail-item-name {
  font-size: 14px;
  color: #666;
}
.detail-item-price {
  font-size: 14px;
  color: #666;
}
.detail-text {
  display: block;
  font-size: 14px;
  color: #666;
  line-height: 1.6;
}
.detail-total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12px;
  border-top: 0.5px solid #f0f0f0;
  margin-top: 8px;
}
.detail-total-label {
  font-size: 15px;
  color: #333;
  font-weight: 600;
}
.detail-total-price {
  font-size: 22px;
  font-weight: 700;
  color: #ff4d4f;
}
.detail-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 12px;
}
