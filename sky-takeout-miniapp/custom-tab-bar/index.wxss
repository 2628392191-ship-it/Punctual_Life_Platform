/* custom-tab-bar/index.wxss */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  border-top: 0.5px solid #eee;
  height: 50px;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2px 0;
}

.tab-icon {
  font-size: 20px;
  line-height: 1;
  margin-bottom: 2px;
}

.tab-text {
  font-size: 10px;
  color: #999;
  line-height: 1;
}

.tab-item.active .tab-text {
  color: #ff6b35;
  font-weight: 600;
}
